{
  "expo": {
    "name": "HK School Finder",
    "slug": "hk-school-finder",
    "version": "1.0.0",
    "scheme": "hk-school-finder",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hkschoolfinder.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#1E3A5F"
      },
      "package": "com.hkschoolfinder.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCYsGXvWu1-tMQSTvxG7eG3oVBiVTy7c7o"
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-localization",
      "expo-sqlite",
      [
        "expo-location",
        { "locationWhenInUsePermission": "Allow HK School Finder to use your location to show nearby schools on the map." }
      ],
      [
        "expo-notifications",
        { "icon": "./assets/icon.png" }
      ],
      [
        "expo-calendar",
        { "calendarPermission": "Allow HK School Finder to export events to your calendar." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
